# --- Ollama ---
OLLAMA_MODEL=deepseek-r1:7b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_MODEL_SUPPORTS_TOOLS=false

# --- Redis（会话 JSON：messages + summary）---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SOCKET_CONNECT_TIMEOUT=0.5
REDIS_SOCKET_TIMEOUT=0.5

# --- Milvus（向量库；未就绪时可关闭 RAG）---
MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION=chat_knowledge
MILVUS_TIMEOUT=1.0
# 为 true 时不初始化向量库（仅工具 / 记忆）
SKIP_MILVUS=true
# 为 false 时不注册 search_knowledge 工具
USE_RAG=false

# --- Agent / 记忆 ---
MEMORY_WINDOW_PAIRS=6
# 在 Agent 文本输出后，再用一次 LLM 整理为 ChatOutput（可关）
STREAM_OUTPUT=true
STREAM_OUTPUT_FORMAT=plain
STRUCTURED_OUTPUT=false
# 内置工具包含当前时间、离线天气、会话上下文和可选知识库检索

# --- 后台任务 ---
JOB_QUEUE_MAX=256
# 每轮对话后异步触发摘要压缩（占位实现，走同一 worker 队列）
ASYNC_SUMMARY_UPDATE=true

# --- PostgreSQL 持久化（默认关闭）---
ENABLE_POSTGRES_PERSISTENCE=false
POSTGRES_DSN=postgresql://postgres:postgres@127.0.0.1:5432/slothbearflow
POSTGRES_CONNECT_TIMEOUT=3.0

# --- 日志 ---
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=app.log

# --- LangSmith（可选）---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=langchain-prod-agent

# Copy to backend/.env.e2e.local for deterministic local end-to-end validation.
# The local file is ignored by Git and is only loaded by docker-compose.e2e.yml.

APP_ENV=local
APP_RELEASE=e2e-local
AUTH_REQUIRED=true
AUTH_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS
AUTH_USERS_JSON={"admin":{"user_id":"e2e-admin","tenant_id":"e2e","roles":["admin"],"password_hash":"CHANGE_ME_PBKDF2_HASH"}}
AUTH_COOKIE_SECURE=false
CORS_ORIGINS_JSON=["http://127.0.0.1:8001","http://localhost:8001"]

LLM_PROVIDER=openai
LLM_MODEL=slothbearflow-e2e
LLM_SUPPORTS_TOOLS=true
LLM_HEALTHCHECK_ENABLED=true
OPENAI_MODEL=slothbearflow-e2e
OPENAI_API_KEY=local-e2e-key
OPENAI_BASE_URL=http://host.docker.internal:18080/v1
OPENAI_MODEL_SUPPORTS_TOOLS=true
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=slothbearflow-e2e-embedding
OPENAI_EMBED_MODEL=slothbearflow-e2e-embedding

USE_RAG=true
SKIP_MILVUS=false
MILVUS_COLLECTION=slothbearflow_e2e
RAG_ALLOW_LEGACY_DOCUMENTS=false
RAG_MULTI_QUERY=false
RAG_RERANKER_PROVIDER=lexical
ENABLE_POSTGRES_PERSISTENCE=true
MEMORY_REDACT_PII=true
REVIEW_ENABLED=false

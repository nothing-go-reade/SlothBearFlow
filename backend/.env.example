# --- Runtime / release ---
APP_ENV=local
APP_RELEASE=dev

# --- LLM Provider ---
LLM_PROVIDER=ollama
# 可选：统一覆盖 provider 默认模型名；留空则走各 provider 自己的默认模型
LLM_MODEL=
# 可选：统一覆盖工具调用能力；留空则走各 provider 默认判断
LLM_SUPPORTS_TOOLS=
# 生产必须 true；本地可关闭，避免每次 /ready 都访问模型服务。
LLM_HEALTHCHECK_ENABLED=false
LLM_HEALTHCHECK_TIMEOUT_SEC=2
# 全局模型参数（会被 provider 专属项覆盖）
LLM_TEMPERATURE=
LLM_TOP_P=
LLM_MAX_TOKENS=
# 抽象“深度思考”开关：true 时若未指定 effort，则映射 reasoning_effort=high
LLM_DEEP_THINK=
# 可选值建议：low / medium / high
LLM_REASONING_EFFORT=
# JSON 对象字符串（如 {"response_format":{"type":"json_object"}}）
LLM_MODEL_KWARGS_JSON=
# OpenAI-compatible 私有参数透传（JSON 对象字符串）
LLM_EXTRA_BODY_JSON=

# --- Ollama ---
OLLAMA_MODEL=deepseek-r1:7b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_MODEL_SUPPORTS_TOOLS=false

# --- OpenAI / OpenAI-compatible ---
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL_SUPPORTS_TOOLS=true
OPENAI_EMBED_MODEL=text-embedding-3-small
# OpenAI 专属参数（优先级高于全局 LLM_*）
OPENAI_TEMPERATURE=
OPENAI_TOP_P=
OPENAI_MAX_TOKENS=
OPENAI_DEEP_THINK=
OPENAI_REASONING_EFFORT=
OPENAI_MODEL_KWARGS_JSON=
OPENAI_EXTRA_BODY_JSON=

# --- Embedding Provider（默认跟随 LLM_PROVIDER）---
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=

# --- Redis（会话 JSON：messages + summary）---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SOCKET_CONNECT_TIMEOUT=0.5
REDIS_SOCKET_TIMEOUT=0.5

# --- Milvus（向量库；未就绪时可关闭 RAG）---
MILVUS_URI=http://127.0.0.1:19530
# 本地未启用 Milvus 鉴权时留空；production 必须提供已配置的 token。
MILVUS_TOKEN=
# production Compose 首次启动使用；目标 token 生效后仍会优先直接验证目标凭据。
# fresh Milvus 默认值通常为 root:Milvus，请仅通过私有环境文件或 secret 注入。
MILVUS_BOOTSTRAP_TOKEN=
MILVUS_COLLECTION=chat_knowledge
MILVUS_TIMEOUT=1.0
MILVUS_RETRY_INTERVAL_SEC=10
# 为 true 时不初始化向量库（仅工具 / 记忆）；完整本地栈建议 false
SKIP_MILVUS=false
# 为 false 时不注册 search_knowledge 工具；完整本地栈建议 true
USE_RAG=true
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=100
RAG_RETRIEVAL_TOP_K=24
RAG_MAX_CONTEXT_CHUNKS=5
RAG_CONTEXT_MAX_TOKENS=4000
RAG_MULTI_QUERY=true
RAG_RRF_K=60
RAG_RELEVANCE_THRESHOLD=0.12
# none | lexical | cross_encoder（cross_encoder 需安装 rerank extra）
RAG_RERANKER_PROVIDER=lexical
RAG_CROSS_ENCODER_MODEL=BAAI/bge-reranker-base
RAG_BLOCK_PROMPT_INJECTION=true
# 生产多租户必须 false；仅为兼容本地历史知识块而默认 true
RAG_ALLOW_LEGACY_DOCUMENTS=true

# --- Agent / 记忆 ---
MEMORY_WINDOW_PAIRS=6
MEMORY_WINDOW_MAX_TOKENS=6000
MEMORY_TTL_SEC=604800
MEMORY_MAX_MESSAGES=200
MEMORY_REDACT_PII=true
# 为 true 时 /chat 开启流式输出
STREAM_OUTPUT=true
# `plain` 适合 curl / 终端直出；`sse` 适合前端事件流消费
STREAM_OUTPUT_FORMAT=sse
# 默认直接返回自然语言结果；为 true 时再做二段式结构化整理
STRUCTURED_OUTPUT=false
# 内置工具包含当前时间、离线天气、会话上下文和可选知识库检索
AGENT_TIMEOUT_SEC=90
AGENT_MAX_ITERATIONS=4
AGENT_PROMPT_VERSION=v1
REACT_MAX_STEPS=4
ENABLE_EXPLICIT_REACT_RUNTIME=false

# --- 后台任务 ---
JOB_QUEUE_MAX=256
INGEST_MAX_ATTEMPTS=3
INGEST_RETRY_BACKOFF_SEC=5
# 每轮对话后异步触发摘要压缩（占位实现，走同一 worker 队列）
ASYNC_SUMMARY_UPDATE=true
SUMMARY_RETRY_ATTEMPTS=2
SUMMARY_TIMEOUT_SEC=60
SUMMARY_INPUT_MAX_CHARS=24000

# --- PostgreSQL 持久化（默认关闭）---
ENABLE_POSTGRES_PERSISTENCE=true
POSTGRES_DSN=postgresql://postgres:postgres@127.0.0.1:5432/slothbearflow
# production Compose 专用：必须传完整 DSN，密码中的 # / % @ 等字符需 percent-encode。
PRODUCTION_POSTGRES_DSN=
# 仅供一次性 Alembic migrate 服务使用；生产 backend 必须使用上面的 CRUD-only DSN。
MIGRATION_POSTGRES_DSN=
POSTGRES_CONNECT_TIMEOUT=3.0
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=10
# Redis 中会话缺失时，是否尝试从 PostgreSQL 回放恢复
POSTGRES_RESTORE_ON_REDIS_MISS=true
# 每次最多回放多少轮（每轮=user+assistant）
POSTGRES_RESTORE_TURN_LIMIT=20
POSTGRES_RESTORE_REDIS_TTL_SEC=604800

# --- 后台复盘学习层（Hermes Background Review 范式，默认全关 / opt-in）---
# 主回答先返回，回合结束后后台 fork review agent 复盘本轮，把偏好沉淀到 Memory、
# 把可复用做法沉淀到 Skills（Markdown 文件为真相源 + SQLite 索引派生）。不污染主会话。
ENABLE_BACKGROUND_REVIEW=false
# nudge 间隔：每 N 轮复盘一次 memory / skills（两者皆中则合并复盘）
REVIEW_MEMORY_INTERVAL=3
REVIEW_SKILLS_INTERVAL=5
# 学习文件根目录（memory/*.md, skills/*.md, index.sqlite）
REVIEW_BASE_DIR=agent_learning
# 单次复盘最多落盘条数
REVIEW_MAX_ITEMS=5
REVIEW_MIN_CONFIDENCE=0.75
# 复盘用单独模型（留空则复用主 LLM）
REVIEW_MODEL=
# 强制走结构化输出路径（即便模型支持工具调用），便于调试/兼容
REVIEW_FORCE_STRUCTURED=false
# 是否把工具调用轨迹（仅 ExplicitReActRuntime 路径）带入复盘快照
REVIEW_TOOL_TRACE=false
REVIEW_TIMEOUT_SEC=90
# 读回闭环：把历史复盘的 memory/skills 注入下一轮 system prompt（注意会影响 prefix cache）
INJECT_LEARNING_INTO_PROMPT=false
# 读回注入的字符预算上限
LEARNING_PROMPT_BUDGET_CHARS=1200

# --- 工具调用安全（Tool Guard，对标 OWASP LLM08 Excessive Agency，默认 enforce 安全默认）---
# 模式：off（关闭，纯透传）| log（只记录不阻断，观察用）| enforce（强制拦截）
TOOL_GUARD_MODE=enforce
# 工具安全策略文件（YAML）；缺失/解析失败会回退到代码内置默认策略（放行现有只读工具、拒未知）
TOOL_POLICY_FILE=backend/config/tool_policy.yaml
# 单个对话回合的工具调用总上限（策略文件内同名键可覆盖）
MAX_TOOL_CALLS_PER_TURN=8
TOOL_TIMEOUT_SEC=15
TOOL_RETRY_ATTEMPTS=1
TOOL_CIRCUIT_FAILURE_THRESHOLD=3
TOOL_CIRCUIT_RECOVERY_SEC=30
TOOL_OBSERVATION_MAX_CHARS=12000
TOOL_TRACE_OBSERVATION_MAX_CHARS=800
# 工具输出敏感信息脱敏（保守高精度模式）；若 RAG 命中误伤可设 false
TOOL_SCRUB_OUTPUT=true

# --- MCP（默认关闭；工具名使用 mcp__<server>__<tool>）---
MCP_ENABLED=false
# 示例：[{
#   "name":"local-docs","url":"http://127.0.0.1:3001/mcp",
#   "bearer_token_env":"LOCAL_MCP_TOKEN",
#   "allowed_tenants":["local"],"allowed_roles":["viewer"],
#   "allowed_scopes":["chat:write"]
# }]
# 多租户凭据可用 tenant_bearer_token_envs：{"team-a":"TEAM_A_MCP_TOKEN"}。
MCP_SERVERS_JSON=[]
MCP_TOOL_ALLOWLIST_JSON=[]
MCP_ALLOWED_HOSTS_JSON=["127.0.0.1","localhost"]
MCP_TIMEOUT_SEC=10
MCP_DISCOVERY_TTL_SEC=60
# production 中只要存在非 loopback MCP，就必须显式配置受控出站代理。
MCP_EGRESS_PROXY_URL=

# --- Login / JWT / RBAC / tenant isolation ---
# 默认要求认证。仅本机开发可显式设为 false，且匿名请求仍只接受 loopback。
AUTH_REQUIRED=true
# production 至少 32 字符，禁止使用示例值或默认值。
AUTH_SECRET=
AUTH_ISSUER=slothbearflow
AUTH_TOKEN_TTL_SEC=3600
# 只接受 password_hash，不接受明文密码。用 security.auth.hash_password 生成。
# production .env 示例（整段单引号，避免 `$` 被 Compose 当作变量展开）：
# AUTH_USERS_JSON='{"alice":{"password_hash":"pbkdf2_sha256$...","tenant_id":"team-a","roles":["operator"]}}'
AUTH_USERS_JSON={}
AUTH_LOCAL_USER_ID=local-user
AUTH_LOCAL_TENANT_ID=local
# 匿名本地身份默认最小权限；如需更高权限必须显式配置。
AUTH_LOCAL_ROLES_JSON=["viewer"]

# --- Request guards / traffic control ---
RATE_LIMIT_PER_MINUTE=60
CHAT_CONCURRENCY_LIMIT=8
CONCURRENCY_WAIT_SEC=2
API_MAX_REQUEST_BYTES=2000000
CHAT_MESSAGE_MAX_CHARS=20000
INGEST_TEXT_MAX_CHARS=1000000
CORS_ORIGINS_JSON=["http://127.0.0.1:5173","http://localhost:5173"]
DOCS_ENABLED=true
TOOL_APPROVAL_TTL_SEC=900

# --- Evaluation / observability ---
OBSERVABILITY_ENABLED=true
PROMETHEUS_ENABLED=true
METRICS_BEARER_TOKEN=
TRACE_STORE_SIZE=200
TRACE_INCLUDE_CONTENT=false
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://127.0.0.1:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Tamper-evident audit log ---
AUDIT_ENABLED=true
AUDIT_LOG_FILE=logs/audit.jsonl

# --- 日志 ---
LOG_LEVEL=INFO
LOG_DIR=logs
APP_LOG_FILE=app.log
ACCESS_LOG_FILE=access.log
ERROR_LOG_FILE=error.log

# --- LangSmith（可选）---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=langchain-prod-agent

# --- LLM Provider ---
LLM_PROVIDER=ollama
# 可选：统一覆盖 provider 默认模型名；留空则走各 provider 自己的默认模型
LLM_MODEL=
# 可选：统一覆盖工具调用能力；留空则走各 provider 默认判断
LLM_SUPPORTS_TOOLS=
# 全局模型参数（会被 provider 专属项覆盖）
LLM_TEMPERATURE=
LLM_TOP_P=
LLM_MAX_TOKENS=
# 抽象“深度思考”开关：true 时若未指定 effort，则映射 reasoning_effort=high
LLM_DEEP_THINK=
# 可选值建议：low / medium / high
LLM_REASONING_EFFORT=
# JSON 对象字符串（如 {"response_format":{"type":"json_object"}}）
LLM_MODEL_KWARGS_JSON=
# OpenAI-compatible 私有参数透传（JSON 对象字符串）
LLM_EXTRA_BODY_JSON=

# --- Ollama ---
OLLAMA_MODEL=deepseek-r1:7b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_MODEL_SUPPORTS_TOOLS=false

# --- OpenAI / OpenAI-compatible ---
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL_SUPPORTS_TOOLS=true
OPENAI_EMBED_MODEL=text-embedding-3-small
# OpenAI 专属参数（优先级高于全局 LLM_*）
OPENAI_TEMPERATURE=
OPENAI_TOP_P=
OPENAI_MAX_TOKENS=
OPENAI_DEEP_THINK=
OPENAI_REASONING_EFFORT=
OPENAI_MODEL_KWARGS_JSON=
OPENAI_EXTRA_BODY_JSON=

# --- Embedding Provider（默认跟随 LLM_PROVIDER）---
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=

# --- Redis（会话 JSON：messages + summary）---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SOCKET_CONNECT_TIMEOUT=0.5
REDIS_SOCKET_TIMEOUT=0.5

# --- Milvus（向量库；未就绪时可关闭 RAG）---
MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION=chat_knowledge
MILVUS_TIMEOUT=1.0
# 为 true 时不初始化向量库（仅工具 / 记忆）；完整本地栈建议 false
SKIP_MILVUS=false
# 为 false 时不注册 search_knowledge 工具；完整本地栈建议 true
USE_RAG=true

# --- Agent / 记忆 ---
MEMORY_WINDOW_PAIRS=6
# 为 true 时 /chat 开启流式输出
STREAM_OUTPUT=true
# `plain` 适合 curl / 终端直出；`sse` 适合前端事件流消费
STREAM_OUTPUT_FORMAT=sse
# 默认直接返回自然语言结果；为 true 时再做二段式结构化整理
STRUCTURED_OUTPUT=false
# 内置工具包含当前时间、离线天气、会话上下文和可选知识库检索

# --- 后台任务 ---
JOB_QUEUE_MAX=256
# 每轮对话后异步触发摘要压缩（占位实现，走同一 worker 队列）
ASYNC_SUMMARY_UPDATE=true

# --- PostgreSQL 持久化（默认关闭）---
ENABLE_POSTGRES_PERSISTENCE=true
POSTGRES_DSN=postgresql://postgres:postgres@127.0.0.1:5432/slothbearflow
POSTGRES_CONNECT_TIMEOUT=3.0
# Redis 中会话缺失时，是否尝试从 PostgreSQL 回放恢复
POSTGRES_RESTORE_ON_REDIS_MISS=true
# 每次最多回放多少轮（每轮=user+assistant）
POSTGRES_RESTORE_TURN_LIMIT=20
POSTGRES_RESTORE_REDIS_TTL_SEC=604800

# --- 后台复盘学习层（Hermes Background Review 范式，默认全关 / opt-in）---
# 主回答先返回，回合结束后后台 fork review agent 复盘本轮，把偏好沉淀到 Memory、
# 把可复用做法沉淀到 Skills（Markdown 文件为真相源 + SQLite 索引派生）。不污染主会话。
ENABLE_BACKGROUND_REVIEW=false
# nudge 间隔：每 N 轮复盘一次 memory / skills（两者皆中则合并复盘）
REVIEW_MEMORY_INTERVAL=3
REVIEW_SKILLS_INTERVAL=5
# 学习文件根目录（memory/*.md, skills/*.md, index.sqlite）
REVIEW_BASE_DIR=agent_learning
# 单次复盘最多落盘条数
REVIEW_MAX_ITEMS=5
# 复盘用单独模型（留空则复用主 LLM）
REVIEW_MODEL=
# 强制走结构化输出路径（即便模型支持工具调用），便于调试/兼容
REVIEW_FORCE_STRUCTURED=false
# 是否把工具调用轨迹（仅 ExplicitReActRuntime 路径）带入复盘快照
REVIEW_TOOL_TRACE=false
# 读回闭环：把历史复盘的 memory/skills 注入下一轮 system prompt（注意会影响 prefix cache）
INJECT_LEARNING_INTO_PROMPT=false
# 读回注入的字符预算上限
LEARNING_PROMPT_BUDGET_CHARS=1200

# --- 工具调用安全（Tool Guard，对标 OWASP LLM08 Excessive Agency，默认 enforce 安全默认）---
# 模式：off（关闭，纯透传）| log（只记录不阻断，观察用）| enforce（强制拦截）
TOOL_GUARD_MODE=enforce
# 工具安全策略文件（YAML）；缺失/解析失败会回退到代码内置默认策略（放行现有只读工具、拒未知）
TOOL_POLICY_FILE=backend/config/tool_policy.yaml
# 单个对话回合的工具调用总上限（策略文件内同名键可覆盖）
MAX_TOOL_CALLS_PER_TURN=8
# 工具输出敏感信息脱敏（保守高精度模式）；若 RAG 命中误伤可设 false
TOOL_SCRUB_OUTPUT=true

# --- 日志 ---
LOG_LEVEL=INFO
LOG_DIR=logs
APP_LOG_FILE=app.log
ACCESS_LOG_FILE=access.log
ERROR_LOG_FILE=error.log

# --- LangSmith（可选）---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=langchain-prod-agent

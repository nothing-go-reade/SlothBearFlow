# Generate a private, ready-to-run file with:
# python3 backend/scripts/generate_observability_env.py

LANGFUSE_POSTGRES_PASSWORD=CHANGE_ME
LANGFUSE_SALT=CHANGE_ME
LANGFUSE_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARACTERS
LANGFUSE_CLICKHOUSE_PASSWORD=CHANGE_ME
LANGFUSE_REDIS_PASSWORD=CHANGE_ME
LANGFUSE_MINIO_ROOT_USER=langfuse
LANGFUSE_MINIO_ROOT_PASSWORD=CHANGE_ME
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME
LANGFUSE_VERSION=3.217.0
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
METRICS_BEARER_TOKEN=CHANGE_ME

LANGFUSE_INIT_ORG_ID=slothbearflow
LANGFUSE_INIT_ORG_NAME=SlothBearFlow
LANGFUSE_INIT_PROJECT_ID=slothbearflow-agent
LANGFUSE_INIT_PROJECT_NAME=SlothBearFlow Agent
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=CHANGE_ME
LANGFUSE_INIT_PROJECT_SECRET_KEY=CHANGE_ME
LANGFUSE_INIT_USER_EMAIL=admin@slothbearflow.local
LANGFUSE_INIT_USER_NAME=SlothBearFlow Admin
LANGFUSE_INIT_USER_PASSWORD=CHANGE_ME

OBSERVABILITY_ENABLED=true
PROMETHEUS_ENABLED=true
LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=CHANGE_ME_SAME_AS_INIT_PROJECT_PUBLIC_KEY
LANGFUSE_SECRET_KEY=CHANGE_ME_SAME_AS_INIT_PROJECT_SECRET_KEY
